{
  "name": "Node 20 + Python 3.12",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20",
      "nodeGypDependencies": true
    },
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "vscode-icons-team.vscode-icons"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "editor.formatOnSave": true,
        "Backslash.enableDebugLogs": true
      }
    }
  },
  "postCreateCommand": "node --version && python --version",
  "postStartCommand": "code --install-extension ${containerWorkspaceFolder}/backslash-scan-*.vsix --force 2>/dev/null || true",
  "remoteUser": "vscode"
}
